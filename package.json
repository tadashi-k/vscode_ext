{
	"name": "editext",
	"displayName": "Edit Extension",
	"description": "Advanced text editing commands inspired by Emacs keybindings",
	"version": "0.0.1",
	"publisher": "tadashi",
	"repository": {
		"type": "git",
		"url": "https://github.com/tadashi-k/vscode_ext"
	},
	"engines": {
		"vscode": "^1.63.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:extension.deleteLine",
		"onCommand:extension.deleteEndOfLine",
		"onCommand:extension.deleteWord",
		"onCommand:extension.yank",
		"onCommand:extension.copyAndUnselect",
		"onCommand:extension.cut",
		"onCommand:extension.paste",
		"onCommand:extension.wordComplete",
		"onCommand:extension.nextWord",
		"onCommand:extension.prevWord",
		"onCommand:extension.nextLine",
		"onCommand:extension.nextLineSelect",
		"onCommand:extension.prevLine",
		"onCommand:extension.prevLineSelect",
		"onCommand:extension.mark",
		"onCommand:extension.swapMark",
		"onCommand:extension.gotoMark",
		"onCommand:extension.macroRecord",
		"onCommand:extension.macroReplay",
		"onCommand:extension.openFile"
	],
	"main": "./out/extension",
	"contributes": {
		"commands": [
			{
				"command": "extension.deleteLine",
				"title": "Delete line",
				"category": "edit"
			},
			{
				"command": "extension.deleteEndOfLine",
				"title": "Delete to end of line",
				"category": "edit"
			},
			{
				"command": "extension.deleteWord",
				"title": "Delete current word",
				"category": "edit"
			},
			{
				"command": "extension.yank",
				"title": "Yank",
				"category": "edit"
			},
			{
				"command": "extension.copyAndUnselect",
				"title": "Copy and unselect",
				"category": "edit"
			},
			{
				"command": "extension.cut",
				"title": "Cut",
				"category": "edit"
			},
			{
				"command": "extension.paste",
				"title": "Pate",
				"category": "edit"
			},
			{
				"command": "extension.wordComplete",
				"title": "Word complete",
				"category": "edit"
			},
			{
				"command": "extension.nextWord",
				"title": "Next word",
				"category": "move"
			},
			{
				"command": "extension.prevWord",
				"title": "Previous word",
				"category": "move"
			},
			{
				"command": "extension.nextLine",
				"title": "Next line",
				"category": "move"
			},
			{
				"command": "extension.nextLineSelect",
				"title": "Next line with selection",
				"category": "move"
			},
			{
				"command": "extension.prevLine",
				"title": "Previous line",
				"category": "move"
			},
			{
				"command": "extension.prevLineSelect",
				"title": "Previous line with selection",
				"category": "move"
			},
			{
				"command": "extension.mark",
				"title": "Mark current position",
				"category": "move"
			},
			{
				"command": "extension.swapMark",
				"title": "Swap mark and current position",
				"category": "move"
			},
			{
				"command": "extension.gotoMark",
				"title": "Go to selected mark position",
				"category": "move"
			},
			{
				"command": "extension.macroRecord",
				"title": "Start and stop macro recoding",
				"category": "macro"
			},
			{
				"command": "extension.macroReplay",
				"title": "Marco replay",
				"category": "macro"
			},
			{
				"command": "extension.openFile",
				"title": "Open file",
				"category": "file"
			},
			{
				"command": "extension.searchWord",
				"title": "Search word",
				"category": "search"
			}
		],
		"keybindings": [
			{
				"command": "extension.deleteLine",
				"key": "ctrl+y"
			},
			{
				"command": "extension.deleteEndOfLine",
				"key": "ctrl+k"
			},
			{
				"command": "extension.deleteWord",
				"key": "ctrl+t"
			},
			{
				"command": "extension.yank",
				"key": "ctrl+l"
			},
			{
				"command": "extension.wordComplete",
				"key": "ctrl+n"
			},
			{
				"command": "extension.nextWord",
				"key": "ctrl+f"
			},
			{
				"command": "extension.prevWord",
				"key": "ctrl+a"
			},
			{
				"command": "extension.mark",
				"key": "escape space",
				"when": "textInputFocus && !suggestWidgetVisible && !findWidgetVisible"
			},
			{
				"key": "escape p",
				"command": "extension.gotoMark",
				"when": "textInputFocus && !suggestWidgetVisible && !findWidgetVisible"
			},
			{
				"command": "extension.swapMark",
				"key": "ctrl+p"
			},
			{
				"key": "ctrl+[",
				"command": "extension.macroReplay"
			},
			{
				"key": "escape [",
				"command": "extension.macroRecord",
				"when": "textInputFocus && !suggestWidgetVisible && !findWidgetVisible"
			},
			{
				"key": "escape f",
				"command": "extension.openFile",
				"when": "textInputFocus && !suggestWidgetVisible && !findWidgetVisible"
			},
			{
				"key": "escape s",
				"command": "extension.searchWord",
				"when": "textInputFocus && !suggestWidgetVisible && !findWidgetVisible"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"build": "tsc -p tsconfig.json",
		"setup": "npm install --production",
		"pack": "vsce package",
		"test": "mocha"
	},
	"ts-node": {
		"project": "tsconfig.test.json",
		"transpileOnly": true
	},
	"devDependencies": {
		"@types/glob": "^7.1.4",
		"@types/mocha": "^10.0.10",
		"@types/node": "14.x",
		"@types/vscode": "^1.62.3",
		"@typescript-eslint/eslint-plugin": "^5.1.0",
		"@typescript-eslint/parser": "^5.1.0",
		"@vscode/test-electron": "^2.5.2",
		"@vscode/vsce": "^3.9.1",
		"eslint": "^8.1.0",
		"glob": "^7.1.7",
		"mocha": "^11.3.0",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^4.9.5"
	}
}
